<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#121212">
    <LinearLayout android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <!-- HEADER -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_name" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" android:layout_centerInParent="true"/>
            <Button android:id="@+id/btnSettings" android:layout_width="40dp" android:layout_height="40dp" android:text="⚙️" android:textSize="18sp" android:backgroundTint="#222" android:textColor="#FFF" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- DESCRIPTION -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="- Converts overcome domains into negative gameplay\n- Overcomes illicit and obscene material\n- Overcomes VPNs and self-uninstall\n- Supports custom write-only overcome list\n- Overcomes self-removal via safe mode"
            android:textColor="#AAAAAA" android:textSize="13sp" android:layout_marginBottom="24dp" android:lineSpacingExtra="6dp"/>

        <!-- INJECTED CARDS -->
        <include layout="@layout/card_onboarding"/>

        <!-- SAFARI CARD -->
        <LinearLayout style="@style/AppCard">
            <CheckBox android:id="@+id/cbGamification" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Enable Netbeast Gamification" android:textColor="#FFFFFF" android:buttonTint="#4CAF50" android:layout_marginBottom="16dp" android:checked="true"/>
            <Button android:id="@+id/btnGame" style="@style/AppButton.Accent" android:backgroundTint="#FF9800" android:text="OPEN NETBEAST SAFARI" android:layout_marginBottom="0dp"/>
        </LinearLayout>

        <include layout="@layout/card_overcome"/>
        <include layout="@layout/card_debug"/>

    </LinearLayout>
</ScrollView>