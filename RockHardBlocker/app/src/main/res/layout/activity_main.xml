<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#121212">
    <LinearLayout android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/app_name" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_marginTop="16dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="- Converts overcome domains into negative gameplay\n- Overcomes illicit and obscene material\n- Overcomes VPNs and self-uninstall\n- Supports custom write-only overcome list\n- Overcomes self-removal via safe mode"
            android:textColor="#AAAAAA" android:textSize="14sp" android:layout_marginBottom="24dp" android:lineSpacingExtra="6dp"/>

        <!-- ONBOARDING CARD -->
        <LinearLayout android:id="@+id/llOnboarding" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"
            android:background="@drawable/bg_card" android:padding="20dp" android:layout_marginBottom="24dp">
            
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SYSTEM SETUP" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

            <Button android:id="@+id/btnStep1" android:layout_width="match_parent" android:layout_height="55dp"
                android:text="1. ENABLE GUARDIAN" android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:elevation="0dp"/>

            <Button android:id="@+id/btnStep2" android:layout_width="match_parent" android:layout_height="55dp"
                android:text="2. LOCK DEVICE" android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:elevation="0dp"/>

            <Button android:id="@+id/btnStep3" android:layout_width="match_parent" android:layout_height="55dp"
                android:text="3. SET UP DNS FILTER" android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:elevation="0dp"/>
                
            <Button android:id="@+id/btnTestFilter" android:layout_width="match_parent" android:layout_height="55dp"
                android:text="VERIFY DNS (UNLOCKS REWARD)" android:background="@drawable/bg_btn_accent" android:textColor="#FFFFFF" android:elevation="0dp"/>
        </LinearLayout>

        <!-- SAFARI / GAMIFICATION CARD -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"
            android:background="@drawable/bg_card" android:padding="20dp" android:layout_marginBottom="24dp">
            
            <CheckBox android:id="@+id/cbGamification" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Enable Netbeast Gamification" android:textColor="#FFFFFF" android:buttonTint="#4CAF50" android:layout_marginBottom="16dp" android:checked="true"/>

            <Button android:id="@+id/btnGame" android:layout_width="match_parent" android:layout_height="60dp"
                android:text="OPEN NETBEAST SAFARI" android:background="@drawable/bg_btn_accent" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textStyle="bold" android:elevation="0dp"/>
        </LinearLayout>

        <!-- CUSTOM OVERCOME LIST CARD -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"
            android:background="@drawable/bg_card" android:padding="20dp" android:layout_marginBottom="32dp">
            
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="CUSTOM OVERCOME LIST (Write Only)" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/etCustomBlock" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp"
                    android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:hint="e.g. youtube" android:textColorHint="#777" android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnAddBlock" android:layout_width="wrap_content" android:layout_height="50dp"
                    android:text="OVERCOME" android:background="@drawable/bg_btn_warning" android:textColor="#FFF" android:elevation="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- DEBUG CONTROLS -->
        <Button android:id="@+id/btnDebugReset" android:layout_width="match_parent" android:layout_height="50dp"
            android:text="DEBUG: RESET SAVE FILE" android:background="@drawable/bg_btn_standard" android:backgroundTint="#7B1FA2" android:textColor="#FFFFFF" android:elevation="0dp" android:layout_marginBottom="12dp"/>
            
        <Button android:id="@+id/btnDebugUninstall" android:layout_width="match_parent" android:layout_height="50dp"
            android:text="DEBUG: KILL &amp; UNINSTALL" android:background="@drawable/bg_btn_standard" android:textColor="#FFCDD2" android:elevation="0dp" android:layout_marginBottom="32dp"/>
    </LinearLayout>
</ScrollView>
