<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.rockhard.blocker.behaviour"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <application
        android:allowBackup="true"
        android:extractNativeLibs="false"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.NoTitleBar" >
        <activity
            android:name="com.rockhard.blocker.MainActivity"
            android:exported="true" /> <!-- GAME ICON ALIAS (Swapped dynamically!) -->
        <activity-alias
            android:name="com.rockhard.blocker.GameLauncher"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_game"
            android:targetActivity="com.rockhard.blocker.MainActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias> <!-- DEFAULT ICON ALIAS -->
        <activity-alias
            android:name="com.rockhard.blocker.DefaultLauncher"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:targetActivity="com.rockhard.blocker.MainActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity
            android:name="com.rockhard.blocker.TrapActivity"
            android:exported="false"
            android:launchMode="singleTask" />
        <activity
            android:name="com.rockhard.blocker.GameActivity"
            android:exported="false"
            android:launchMode="singleTask" />

        <service
            android:name="com.rockhard.blocker.GuardianService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/guardian_config" />
        </service>

        <receiver
            android:name="com.rockhard.blocker.AdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN" >
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />

            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>