<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:background="#E53935" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/overlay_title" android:textColor="#FFFFFF" android:textSize="36sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="You are attempting to disable your protections. The Rock Hard Shield has intercepted your screen."
        android:textColor="#FFFFFF" android:textSize="18sp" android:textAlignment="center" android:layout_marginBottom="48dp"/>

    <Button android:id="@+id/btnYield" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="I YIELD (RETURN TO HOME)" android:backgroundTint="#000000" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginBottom="16dp"/>
        
    <Button android:id="@+id/btnPauseBlocker" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="I WANT TO PAUSE THE BLOCKER" android:backgroundTint="#B71C1C" android:textColor="#FFCDD2" android:textStyle="bold"/>
</LinearLayout>
