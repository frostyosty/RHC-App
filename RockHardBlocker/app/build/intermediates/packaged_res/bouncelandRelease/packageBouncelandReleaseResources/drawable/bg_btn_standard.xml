<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- PRESSED STATE (Shifted Down) -->
    <item android:state_pressed="true">
        <layer-list>
            <item><shape><corners android:radius="8dp"/><solid android:color="#151515"/></shape></item>
            <item android:top="4dp" android:bottom="0dp"><shape><corners android:radius="8dp"/><gradient android:angle="270" android:startColor="#2A2A2A" android:endColor="#3A3A3A"/></shape></item>
        </layer-list>
    </item>
    <!-- DEFAULT STATE (Raised) -->
    <item>
        <layer-list>
            <item><shape><corners android:radius="8dp"/><solid android:color="#151515"/></shape></item>
            <item android:top="0dp" android:bottom="4dp"><shape><corners android:radius="8dp"/><gradient android:angle="270" android:startColor="#3A3A3A" android:endColor="#4D4D4D"/></shape></item>
        </layer-list>
    </item>
</selector>
