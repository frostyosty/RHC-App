<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item><shape><corners android:radius="8dp"/><solid android:color="#003300"/></shape></item>
            <item android:top="4dp" android:bottom="0dp"><shape><corners android:radius="8dp"/><gradient android:angle="270" android:startColor="#124016" android:endColor="#1e5c22"/></shape></item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item><shape><corners android:radius="8dp"/><solid android:color="#003300"/></shape></item>
            <item android:top="0dp" android:bottom="4dp"><shape><corners android:radius="8dp"/><gradient android:angle="270" android:startColor="#1B5E20" android:endColor="#2E7D32"/></shape></item>
        </layer-list>
    </item>
</selector>
