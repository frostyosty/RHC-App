<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/navTabs" android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal">
    <Button android:id="@+id/tabActivity" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="EXPLORE" android:backgroundTint="#333333" android:textColor="#00FF00" android:textSize="12sp"/>
    <Button android:id="@+id/tabParty" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="PARTY" android:backgroundTint="#111111" android:textColor="#888888" android:textSize="12sp"/>
    <Button android:id="@+id/tabBag" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="BAG/SHOP" android:backgroundTint="#111111" android:textColor="#888888" android:textSize="12sp"/>
</LinearLayout>
