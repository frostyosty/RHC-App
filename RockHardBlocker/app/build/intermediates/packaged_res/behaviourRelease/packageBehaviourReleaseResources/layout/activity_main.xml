<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp" android:gravity="center" android:background="#121212">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/app_name" android:textColor="#FFFFFF" android:textSize="28sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>

    <Button android:id="@+id/btnArmShield" android:layout_width="match_parent" android:layout_height="70dp"
        android:text="ARM THE SHIELD" android:backgroundTint="#4CAF50" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnHumiliation" android:layout_width="match_parent" android:layout_height="50dp"
        android:text="BOUNCEMON SAFARI" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnTrapBrick" android:layout_width="match_parent" android:layout_height="50dp"
        android:text="EMERGENCY LOCKDOWN (10 MIN)" android:backgroundTint="#E53935" android:textColor="#FFFFFF" android:layout_marginBottom="32dp"/>

    <Button android:id="@+id/btnTestFilter" android:layout_width="match_parent" android:layout_height="40dp"
        android:text="DEBUG: TEST ILLICIT WEBSITES" android:backgroundTint="#2196F3" android:textColor="#FFFFFF" android:layout_marginBottom="8dp"/>

    <!-- NEW: ANALYTICS TRACKER BUTTON -->
    <Button android:id="@+id/btnDebugUsage" android:layout_width="match_parent" android:layout_height="40dp"
        android:text="DEBUG: VIEW SCREEN TRACKING" android:backgroundTint="#9C27B0" android:textColor="#FFFFFF" android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnDebugUninstall" android:layout_width="match_parent" android:layout_height="40dp"
        android:text="DEBUG: KILL &amp; UNINSTALL" android:backgroundTint="#555555" android:textColor="#FFCDD2"/>
</LinearLayout>
