<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#121212">
    <LinearLayout android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
        
        <!-- HEADER WITH SETTINGS GEAR -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_name" android:textColor="#FFFFFF" android:textSize="30sp" android:textStyle="bold" android:layout_centerInParent="true"/>
            <Button android:id="@+id/btnSettings" android:layout_width="40dp" android:layout_height="40dp" android:text="⚙️" android:textSize="18sp" android:backgroundTint="#222" android:textColor="#FFF" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
        </RelativeLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="- Converts positive domains into Christian gameplay mechanics\n- Overcomes illicit and obscene material\n- Overcomes VPNs and self-uninstall\n- Supports custom write-only overcome list\n- Overcomes self-removal via safe mode"
            android:textColor="#AAAAAA" android:textSize="13sp" android:layout_marginBottom="24dp" android:lineSpacingExtra="6dp"/>

        <LinearLayout android:id="@+id/llOnboarding" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="20dp" android:layout_marginBottom="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SYSTEM SETUP" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>
            <Button android:id="@+id/btnStep1" android:layout_width="match_parent" android:layout_height="55dp" android:text="1. ENABLE GUARDIAN" android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:elevation="0dp"/>
            <Button android:id="@+id/btnStep2" android:layout_width="match_parent" android:layout_height="55dp" android:text="2. LOCK DEVICE" android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:elevation="0dp"/>
            <Button android:id="@+id/btnStep3" android:layout_width="match_parent" android:layout_height="55dp" android:text="3. SET UP DNS FILTER" android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:elevation="0dp"/>
            <Button android:id="@+id/btnTestFilter" android:layout_width="match_parent" android:layout_height="55dp" android:text="VERIFY DNS (UNLOCKS REWARD)" android:background="@drawable/bg_btn_accent" android:textColor="#FFFFFF" android:elevation="0dp"/>
        </LinearLayout>

        <Button android:id="@+id/btnGame" android:layout_width="match_parent" android:layout_height="60dp" android:text="OPEN NETBEAST SAFARI" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginBottom="24dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_card" android:padding="20dp" android:layout_marginBottom="32dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CUSTOM OVERCOME LIST (Write Only)" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/etCustomBlock" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:background="@drawable/bg_btn_standard" android:textColor="#FFFFFF" android:hint="e.g. youtube" android:textColorHint="#777" android:paddingHorizontal="16dp" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnAddBlock" android:layout_width="wrap_content" android:layout_height="50dp" android:text="OVERCOME" android:background="@drawable/bg_btn_warning" android:textColor="#FFF" android:elevation="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <Button android:id="@+id/btnDebugReset" android:layout_width="match_parent" android:layout_height="50dp" android:text="DEBUG: RESET SAVE FILE" android:backgroundTint="#7B1FA2" android:textColor="#FFFFFF" android:layout_marginBottom="12dp"/>
        <Button android:id="@+id/btnDebugUninstall" android:layout_width="match_parent" android:layout_height="50dp" android:text="DEBUG: KILL &amp; UNINSTALL" android:backgroundTint="#333333" android:textColor="#FFCDD2" android:layout_marginBottom="32dp"/>
    </LinearLayout>
</ScrollView>
