<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item><shape><corners android:radius="50dp"/><solid android:color="#C56000"/></shape></item>
            <item android:top="4dp" android:bottom="0dp"><shape><corners android:radius="50dp"/><gradient android:angle="270" android:startColor="#ab3c00" android:endColor="#cc7900"/></shape></item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item><shape><corners android:radius="50dp"/><solid android:color="#C56000"/></shape></item>
            <item android:top="0dp" android:bottom="4dp"><shape><corners android:radius="50dp"/><gradient android:angle="270" android:startColor="#E65100" android:endColor="#FF9800"/></shape></item>
        </layer-list>
    </item>
</selector>
