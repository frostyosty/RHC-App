<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/essayBackground"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp" android:background="#121212">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="THE ESCAPE HATCH" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="To pause the blocker for 5 minutes, you must type the following text perfectly. A single typo will reset your progress."
        android:textColor="#AAAAAA" android:textSize="14sp" android:layout_marginBottom="24dp"/>

    <TextView android:id="@+id/tvPrompt" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Loading prompt..." android:textColor="#FFEB3B" android:textSize="18sp" android:textStyle="italic" android:layout_marginBottom="32dp"/>

    <EditText android:id="@+id/etInput" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Start typing here..." android:textColorHint="#777777" android:textColor="#FFFFFF"
        android:backgroundTint="#FFFFFF" android:inputType="textMultiLine|textNoSuggestions"
        android:gravity="top" android:minLines="5"/>
</LinearLayout>
