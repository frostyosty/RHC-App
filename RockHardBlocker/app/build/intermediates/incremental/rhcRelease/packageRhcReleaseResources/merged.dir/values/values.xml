<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name" translatable="false">Rock Hard Christianity</string>
    <string name="brick_message" translatable="false">Oh no, your phone is bricked up.</string>
    <string name="essay_prompt" translatable="false">I am a grown man with a fully functioning prefrontal cortex. I will not lose a psychological battle against a glowing glass rectangle today. I am choosing strength over weakness.</string>
    <string name="flavor_id" translatable="false">rhc</string>
    <string name="overlay_title" translatable="false">NOT TODAY.</string>
    <style name="AppButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">55dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:elevation">0dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="AppButton.Accent">
        <item name="android:background">@drawable/bg_btn_accent</item>
    </style>
    <style name="AppButton.Red">
        <item name="android:backgroundTint">#D32F2F</item>
    </style>
    <style name="AppButton.Standard">
        <item name="android:background">@drawable/bg_btn_standard</item>
    </style>
    <style name="AppCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">20dp</item>
        <item name="android:layout_marginBottom">24dp</item>
    </style>
    <style name="AppTheme" parent="android:Theme.NoTitleBar">
        <item name="android:windowBackground">#121212</item>
    </style>
    <style name="TextConsole">
        <item name="android:textColor">#00FF00</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>
    <style name="TextHeader">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>
</resources>